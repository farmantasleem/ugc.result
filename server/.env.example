# Copy to .env and fill in. .env is gitignored.
PORT=3001

# Required for the /internal/gif/understand route.
OPENAI_API_KEY=sk-...
# Vision-capable, cheap. Override if you want a different model.
OPENAI_MODEL=gpt-4o-mini

# Required for automatic GIF search.
GIPHY_API_KEY=...
# g | pg | pg-13 | r   keeps results clean.
GIPHY_RATING=pg-13

# Required for background image search (https://www.pexels.com/api/).
PEXELS_API_KEY=...

# Optional: upload rendered videos to ImageKit. Set all three to enable;
# otherwise videos are served locally from /videos.
IMAGEKIT_PUBLIC_KEY=...
IMAGEKIT_PRIVATE_KEY=...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
