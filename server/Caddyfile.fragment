# The droplet's existing Caddy (in your other stack) owns 80/443, so the domain
# MUST be served from there. Append this ONE block to that stack's Caddyfile
# (next to the api.murga.app / message.murga.app blocks), then from THAT stack's
# directory run:  docker compose restart caddy
#
# It proxies to the UGC backend's host-published port 3001. Editing this file
# does not affect your server/messaging services.

ugc.murga.app {
	reverse_proxy 139.59.5.247:3001
}
